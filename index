<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes">
    <title>Лента Припоминания</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --bg: #f5f7fa;
            --card-bg: #ffffff;
            --text: #1a1a2e;
            --text-secondary: #4a4a6a;
            --accent: #6c5ce7;
            --shadow: 0 4px 12px rgba(0, 0, 0, 0.05);
            --radius: 16px;
            --spoiler-bg: #f0f0f5;
            --border: #e0e0ea;
            --transition: all 0.2s ease;
            --text-scale: 1;
        }

        html {
            font-size: calc(14px * var(--text-scale));
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: var(--bg);
            color: var(--text);
            padding: 16px;
            display: flex;
            justify-content: center;
            min-height: 100vh;
            transition: var(--transition);
        }

        .container {
            max-width: 500px;
            width: 100%;
        }

        h1 {
            text-align: center;
            font-size: 1.6rem;
            margin-bottom: 16px;
            color: var(--text);
            background: linear-gradient(135deg, var(--accent), #fd79a8);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            display: inline-block;
            width: 100%;
        }

        .form-box {
            background: var(--card-bg);
            border-radius: var(--radius);
            padding: 16px;
            box-shadow: var(--shadow);
            margin-bottom: 16px;
        }

        .form-box input,
        .form-box textarea {
            width: 100%;
            padding: 12px;
            border: 1px solid var(--border);
            border-radius: 8px;
            font-size: 1rem;
            margin-bottom: 10px;
            font-family: inherit;
            background: var(--bg);
            color: var(--text);
            transition: var(--transition);
        }

        .form-box input:focus,
        .form-box textarea:focus {
            border-color: var(--accent);
            outline: none;
            box-shadow: 0 0 0 3px rgba(108, 92, 231, 0.15);
        }

        .form-box textarea {
            resize: vertical;
            min-height: 60px;
        }

        .btn {
            border: none;
            border-radius: 8px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: var(--transition);
            padding: 12px;
        }

        .btn-primary {
            background: var(--accent);
            color: #fff;
            width: 100%;
        }

        .btn-primary:active {
            transform: scale(0.97);
        }

        .btn-shuffle {
            background: #00b894;
            color: #fff;
            padding: 8px 16px;
            width: auto;
        }

        .controls {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 12px;
            flex-wrap: wrap;
            gap: 8px;
        }

        .controls .counter {
            color: var(--text-secondary);
            font-size: 0.9rem;
        }

        .feed {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .card {
            background: var(--card-bg);
            border-radius: var(--radius);
            padding: 16px;
            box-shadow: var(--shadow);
            transition: var(--transition);
        }

        .card:hover {
            box-shadow: 0 6px 20px rgba(0, 0, 0, 0.06);
        }

        .card .question {
            font-size: 1.1rem;
            font-weight: 600;
            margin-bottom: 10px;
            padding-left: 12px;
            border-left: 4px solid var(--accent);
            word-wrap: break-word;
        }

        .answer-block {
            background: var(--spoiler-bg);
            border-radius: 8px;
            padding: 12px;
            cursor: pointer;
            transition: var(--transition);
            border: 1px solid var(--border);
            position: relative;
        }

        .answer-block.revealed {
            background: var(--card-bg);
            border-color: var(--accent);
        }

        .answer-text {
            display: none;
            font-size: 1rem;
            line-height: 1.5;
            color: var(--text);
            word-wrap: break-word;
        }

        .answer-text img {
            max-width: 100%;
            border-radius: 6px;
        }

        .answer-text a {
            color: var(--accent);
            text-decoration: underline;
        }

        .answer-block.revealed .answer-text {
            display: block;
        }

        .answer-block.revealed .placeholder {
            display: none;
        }

        .placeholder {
            color: var(--text-secondary);
            font-size: 0.9rem;
        }

        .edit-actions {
            display: none;
            gap: 8px;
            margin-top: 8px;
            flex-wrap: wrap;
        }

        .answer-block.revealed .edit-actions {
            display: flex;
        }

        .edit-actions .btn-sm {
            border: none;
            padding: 4px 12px;
            border-radius: 6px;
            font-size: 0.8rem;
            cursor: pointer;
            transition: var(--transition);
        }

        .edit-actions .btn-edit {
            background: var(--accent);
            color: #fff;
        }

        .edit-actions .btn-cancel {
            background: #e0e0ea;
            color: #333;
        }

        .edit-area {
            display: none;
            width: 100%;
            padding: 8px;
            border-radius: 6px;
            border: 1px solid var(--border);
            font-family: inherit;
            font-size: 0.95rem;
            margin-top: 6px;
            background: var(--bg);
            color: var(--text);
            resize: vertical;
            min-height: 60px;
        }

        .edit-area.active {
            display: block;
        }

        .card-footer {
            display: flex;
            justify-content: flex-end;
            gap: 8px;
            margin-top: 10px;
        }

        .card-footer .btn-sm {
            background: none;
            border: none;
            color: var(--text-secondary);
            font-size: 0.75rem;
            cursor: pointer;
            padding: 4px 8px;
            border-radius: 4px;
            transition: var(--transition);
        }

        .card-footer .btn-sm:hover {
            background: #fee2e2;
            color: #e11d48;
        }

        .empty {
            text-align: center;
            color: var(--text-secondary);
            padding: 40px 0;
        }

        @media (max-width: 400px) {
            .controls {
                flex-direction: column;
                align-items: stretch;
            }
            .btn-shuffle {
                width: 100%;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>🧠 Лента Припоминания</h1>

        <div class="form-box">
            <input type="text" id="qInput" placeholder="Вопрос..." autocomplete="off">
            <textarea id="aInput" placeholder="Ответ..." autocomplete="off"></textarea>
            <button class="btn btn-primary" id="addBtn">➕ Добавить карточку</button>
        </div>

        <div class="controls">
            <span class="counter" id="counter">📚 0 карточек</span>
            <button class="btn btn-shuffle" id="shuffleBtn">🔀 Перемешать</button>
        </div>

        <div id="feed" class="feed"></div>
    </div>

    <script>
        // ===== Хранилище =====
        const STORAGE_KEY = 'memory_cards_data';
        let cards = loadCards();

        function loadCards() {
            try {
                const saved = localStorage.getItem(STORAGE_KEY);
                if (saved) {
                    const parsed = JSON.parse(saved);
                    if (Array.isArray(parsed) && parsed.length) return parsed;
                }
            } catch (_) {}
            return [
                { q: "💡 В чем главный плюс Активного Припоминания?", a: "Оно заставляет мозг напрягаться, создавая прочные нейронные связи." },
                { q: "📚 Как называется система карточек по ячейкам?", a: "Система Лейтнера (Leitner system)." },
                { q: "🧠 Какой эффект укрепляет память лучше перечитывания?", a: "Эффект тестирования (Testing Effect)." }
            ];
        }

        function saveCards() {
            try {
                localStorage.setItem(STORAGE_KEY, JSON.stringify(cards));
            } catch (_) {}
        }

        // ===== Рендер =====
        function renderFeed() {
            const feed = document.getElementById('feed');
            const counter = document.getElementById('counter');

            if (!cards.length) {
                feed.innerHTML = `<div class="empty">📭 Нет карточек. Добавь свою первую!</div>`;
                counter.textContent = '📚 0 карточек';
                return;
            }

            counter.textContent = `📚 ${cards.length} карточек`;
            feed.innerHTML = '';

            cards.forEach((card, index) => {
                const cardDiv = document.createElement('div');
                cardDiv.className = 'card';
                cardDiv.dataset.index = index;

                cardDiv.innerHTML = `
                    <div class="question">${escapeHtml(card.q)}</div>
                    <div class="answer-block" data-index="${index}">
                        <span class="placeholder">👆 Нажми, чтобы открыть ответ</span>
                        <span class="answer-text">${card.a}</span>
                        <div class="edit-actions">
                            <button class="btn-sm btn-edit edit-btn" data-index="${index}">✏️ Редактировать</button>
                        </div>
                        <textarea class="edit-area" data-index="${index}"></textarea>
                        <div class="edit-actions" style="display:none;">
                            <button class="btn-sm btn-edit save-edit-btn" data-index="${index}">💾 Сохранить</button>
                            <button class="btn-sm btn-cancel cancel-edit-btn" data-index="${index}">Отмена</button>
                        </div>
                    </div>
                    <div class="card-footer">
                        <button class="btn-sm delete-btn" data-index="${index}">🗑 Удалить</button>
                    </div>
                `;

                feed.appendChild(cardDiv);
            });
        }

        // ===== Вспомогательные функции =====
        function escapeHtml(str) {
            if (!str) return '';
            return str
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;');
        }

        function showToast(msg) {
            const el = document.getElementById('toast');
            if (!el) {
                const toast = document.createElement('div');
                toast.id = 'toast';
                toast.style.cssText = `
                    position: fixed; bottom: 30px; left: 50%; transform: translateX(-50%);
                    background: #1a1a2e; color: #fff; padding: 10px 24px; border-radius: 30px;
                    font-size: 14px; font-weight: 500; box-shadow: 0 4px 16px rgba(0,0,0,0.2);
                    opacity: 0; transition: opacity 0.3s; z-index: 999; pointer-events: none;
                `;
                document.body.appendChild(toast);
            }
            const toast = document.getElementById('toast');
            toast.textContent = msg;
            toast.style.opacity = '1';
            clearTimeout(toast._timer);
            toast._timer = setTimeout(() => {
                toast.style.opacity = '0';
            }, 2000);
        }

        // ===== Действия =====
        function addCard() {
            const q = document.getElementById('qInput').value.trim();
            const a = document.getElementById('aInput').value.trim();
            if (!q || !a) {
                showToast('❌ Заполните оба поля');
                return;
            }
            cards.unshift({ q, a });
            document.getElementById('qInput').value = '';
            document.getElementById('aInput').value = '';
            saveCards();
            renderFeed();
            showToast('✅ Добавлено!');
            document.querySelector('.feed')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }

        function deleteCard(index) {
            if (index < 0 || index >= cards.length) return;
            if (!confirm('🗑 Удалить карточку?')) return;
            cards.splice(index, 1);
            saveCards();
            renderFeed();
            showToast('🗑 Удалено');
        }

        function shuffleCards() {
            if (cards.length < 2) {
                showToast('🔀 Мало карточек для перемешивания');
                return;
            }
            for (let i = cards.length - 1; i > 0; i--) {
                const j = Math.floor(Math.random() * (i + 1));
                [cards[i], cards[j]] = [cards[j], cards[i]];
            }
            saveCards();
            renderFeed();
            showToast('🔀 Перемешано!');
        }

        // ===== Редактирование ответа =====
        function openEdit(block) {
            const index = parseInt(block.dataset.index);
            const card = cards[index];
            if (!card) return;

            const display = block.querySelector('.answer-text');
            const editArea = block.querySelector('.edit-area');
            const editActions = block.querySelectorAll('.edit-actions');

            editArea.value = card.a;
            editArea.classList.add('active');
            editArea.style.display = 'block';

            // Показываем кнопки Сохранить/Отмена, скрываем кнопку Редактировать
            editActions[0].style.display = 'none';
            editActions[1].style.display = 'flex';
            display.style.display = 'none';

            editArea.focus();
        }

        function saveEdit(block) {
            const index = parseInt(block.dataset.index);
            const card = cards[index];
            if (!card) return;

            const editArea = block.querySelector('.edit-area');
            const display = block.querySelector('.answer-text');
            const editActions = block.querySelectorAll('.edit-actions');

            const newText = editArea.value.trim();
            if (!newText) {
                showToast('❌ Ответ не может быть пустым');
                return;
            }

            card.a = newText;
            display.innerHTML = newText;
            saveCards();

            editArea.classList.remove('active');
            editArea.style.display = 'none';
            editActions[0].style.display = 'flex';
            editActions[1].style.display = 'none';
            display.style.display = 'block';

            showToast('✅ Ответ обновлён');
        }

        function cancelEdit(block) {
            const display = block.querySelector('.answer-text');
            const editArea = block.querySelector('.edit-area');
            const editActions = block.querySelectorAll('.edit-actions');

            editArea.classList.remove('active');
            editArea.style.display = 'none';
            editActions[0].style.display = 'flex';
            editActions[1].style.display = 'none';
            display.style.display = 'block';
        }

        // ===== Обработчики событий (делегирование) =====
        document.getElementById('feed').addEventListener('click', (e) => {
            const target = e.target;

            // Открыть/закрыть ответ
            const block = target.closest('.answer-block');
            if (block && !target.closest('.edit-actions') && !target.closest('.edit-area')) {
                block.classList.toggle('revealed');
                return;
            }

            // Удалить
            const delBtn = target.closest('.delete-btn');
            if (delBtn) {
                const index = parseInt(delBtn.dataset.index);
                if (!isNaN(index)) deleteCard(index);
                return;
            }

            // Редактировать (кнопка)
            const editBtn = target.closest('.edit-btn');
            if (editBtn) {
                const block = editBtn.closest('.answer-block');
                if (block) openEdit(block);
                return;
            }

            // Сохранить
            const saveBtn = target.closest('.save-edit-btn');
            if (saveBtn) {
                const block = saveBtn.closest('.answer-block');
                if (block) saveEdit(block);
                return;
            }

            // Отмена
            const cancelBtn = target.closest('.cancel-edit-btn');
            if (cancelBtn) {
                const block = cancelBtn.closest('.answer-block');
                if (block) cancelEdit(block);
                return;
            }
        });

        // ===== Кнопки =====
        document.getElementById('addBtn').addEventListener('click', addCard);
        document.getElementById('shuffleBtn').addEventListener('click', shuffleCards);

        document.getElementById('qInput').addEventListener('keydown', (e) => {
            if (e.key === 'Enter') addCard();
        });
        document.getElementById('aInput').addEventListener('keydown', (e) => {
            if (e.key === 'Enter' && !e.shiftKey) {
                e.preventDefault();
                addCard();
            }
        });

        // ===== Старт =====
        renderFeed();
        console.log('🧠 Лента загружена, редактирование ответов работает!');
    </script>
</body>
</html>